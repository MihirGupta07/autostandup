# Database — SQLite for local dev, swap to Postgres URL for production
# Postgres example: postgresql://user:password@localhost:5432/autostandup
DATABASE_URL=sqlite:///./autostandup.db

# Gemini API — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Slack — https://api.slack.com/apps → Create New App
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Webhook secrets (set these in GitHub/GitLab webhook settings)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret

# Standup schedule — cron format, default: 9am Mon-Fri
STANDUP_CRON=0 9 * * 1-5
